## Telegram
TELEGRAM_TOKEN=

## Google Gemini (текст + Imagen 4 Fast). Можно использовать тот же ключ, что и в video-gen-bot.
## Можно указать VERTEX_API_KEY вместо GEMINI_API_KEY — оба читаются.
GEMINI_API_KEY=

## Atlas Cloud — Kling v3 Pro, Seedance 2.0, PixVerse, HappyHorse, FLUX, Ideogram
ATLAS_API_KEY=

## PostgreSQL — общий с video-gen-bot
CORE_DB_NAME=
DB_USERNAME=
DB_PASSWORD=
DB_HOST=postgres
DB_PORT=5432

## Blotato — публикация в TikTok / YouTube
BLOTATO_BASE_URL=https://backend.blotato.com/v2
BLOTATO_API_KEY=

## ElevenLabs — TTS (накладывается поверх сгенерированного видео)
ELEVENLABS_API_KEY=
ELEVENLABS_DEFAULT_VOICE_ID=

## Опциональный outro-клип (subscribe video), который добавляется в конец каждого ролика.
## Оставьте пустым, чтобы отключить.
OUTRO_VIDEO_PATH=
